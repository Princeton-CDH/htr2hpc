#!/usr/bin/env bash

# Automatically sets up your devbox environment whenever you cd into this
# directory via our direnv integration:

eval "$(devbox generate direnv --print-envrc)"

# Unset any VIRTUAL_ENV set by external Python installations (e.g. homebrew)
# so that uv uses the project's own .venv without warnings.
unset VIRTUAL_ENV

# eScriptorium app modules must be on PYTHONPATH for imports to resolve.
# Assumes escriptorium is cloned as a sibling directory; adjust if needed.
export PYTHONPATH="$(pwd)/../escriptorium/app/apps:$(pwd)/../escriptorium/app"

# check out https://www.jetify.com/docs/devbox/ide_configuration/direnv/
# for more details
